---
import { SITE } from '../config';
---

<section id="about" class="min-h-screen flex items-center pt-24 pb-16 px-6">
  <div class="max-w-5xl mx-auto w-full">

    <div class="grid md:grid-cols-[1fr_auto] gap-12 items-center">

      <!-- Text block -->
      <div class="stagger">
        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 font-mono text-xs text-accent
                    border border-accent/30 rounded-full px-3 py-1 mb-6 bg-accent/5">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-dot"></span>
          Available for opportunities
        </div>

        <p class="section-label">Hello, I'm</p>

        <h1 class="font-display text-6xl md:text-8xl font-black text-ink leading-[0.95] mb-4">
          {SITE.name.split(' ')[0]}<br/>
          <span class="text-accent italic">{SITE.name.split(' ')[1]}</span>
        </h1>

        <p class="font-mono text-sm text-accent tracking-widest uppercase mb-6">
          {SITE.role}
        </p>

        <p class="text-ink-muted text-lg leading-relaxed max-w-lg mb-8">
          {SITE.tagline}
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="#projects" class="btn-primary">View my work</a>
          <a href="#contact" class="btn-outline">Get in touch</a>
        </div>

        <!-- Social links -->
        <div class="flex gap-4 mt-8">
          {Object.entries(SITE.social).map(([key, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer"
               class="font-mono text-2xs tracking-widest uppercase text-ink-muted
                      hover:text-accent transition-colors border-b border-transparent hover:border-accent pb-0.5">
              {key}
            </a>
          ))}
        </div>
      </div>

      <!-- Avatar -->
      <div class="flex flex-col items-center gap-4 animate-fade-in">
        <div class="relative">
          <!-- Decorative ring -->
          <div class="absolute inset-0 rounded-3xl border border-accent/20
                      scale-105 rotate-3"></div>
          <div class="absolute inset-0 rounded-3xl border border-accent/10
                      scale-110 -rotate-2"></div>

          <div class="w-48 h-48 md:w-56 md:h-56 rounded-3xl overflow-hidden
                      border border-ink-faint relative z-10
                      bg-bg-card flex items-center justify-center">
            <!-- Replace src with SITE.avatar once you add your photo -->
            <img src={SITE.avatar} alt={SITE.name}
                 class="w-full h-full object-cover"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <!-- Placeholder shown when no photo -->
            <div class="hidden w-full h-full items-center justify-center flex-col gap-2">
              <div class="font-display text-5xl font-black text-accent/30">
                {SITE.name.split(' ').map(w => w[0]).join('')}
              </div>
              <p class="font-mono text-2xs text-ink-faint text-center px-4">
                add avatar.jpg to /public
              </p>
            </div>
          </div>
        </div>

        <!-- Location chip -->
        <div class="flex items-center gap-1.5 font-mono text-2xs text-ink-muted
                    border border-ink-faint rounded-full px-3 py-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {SITE.location}
        </div>
      </div>

    </div>

    <!-- Scroll hint -->
    <div class="mt-16 flex items-center gap-3 text-ink-faint">
      <div class="w-px h-12 bg-gradient-to-b from-transparent to-ink-faint mx-auto md:mx-0"></div>
    </div>

  </div>
</section>
