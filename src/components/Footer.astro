---
import { SITE } from '../config';
---

<footer id="contact" class="py-24 px-6 border-t border-ink-faint/50">
  <div class="max-w-5xl mx-auto">

    <div class="grid md:grid-cols-2 gap-12 items-start">

      <div>
        <p class="section-label">Let's talk</p>
        <h2 class="section-title mb-4">Get in touch</h2>
        <p class="text-ink-muted max-w-sm mb-8">
          Open to interesting problems, new opportunities, and just chatting.
        </p>

        <!-- Copy email button -->
        <button id="copy-email-btn" class="btn-primary group">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
          <span id="copy-email-text">{SITE.email}</span>
        </button>

        <!-- Confirmation toast -->
        <p id="copy-confirm"
           class="mt-3 font-mono text-xs text-accent opacity-0 transition-opacity duration-300 pointer-events-none">
          ✓ Copied to clipboard
        </p>
      </div>

      <div class="flex flex-col items-start md:items-end gap-4 md:pt-2">
        <div class="flex gap-4">
          {Object.entries(SITE.social).map(([key, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer"
               class="font-mono text-xs tracking-widest uppercase
                      text-ink-muted hover:text-accent transition-colors">
              {key}
            </a>
          ))}
        </div>

        <a href={SITE.resume} download class="btn-outline text-xs py-2 px-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Résumé
        </a>
      </div>
    </div>

    <div class="mt-16 pt-6 border-t border-ink-faint/30 flex flex-wrap
                items-center justify-between gap-3">
      <p class="font-mono text-2xs text-ink-faint">Built with Astro + Tailwind</p>
      <p class="font-mono text-2xs text-ink-faint">© {new Date().getFullYear()} {SITE.name}</p>
    </div>

  </div>
</footer>

<script define:vars={{ email: SITE.email }}>
  const btn     = document.getElementById('copy-email-btn');
  const label   = document.getElementById('copy-email-text');
  const confirm = document.getElementById('copy-confirm');
  let timer;

  btn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(email);
    } catch {
      // Fallback for older browsers
      const ta = document.createElement('textarea');
      ta.value = email;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }

    label.textContent = 'Copied!';
    confirm.style.opacity = '1';
    clearTimeout(timer);
    timer = setTimeout(() => {
      label.textContent = email;
      confirm.style.opacity = '0';
    }, 2500);
  });
</script>