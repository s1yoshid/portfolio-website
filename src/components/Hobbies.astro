---
// Hobbies section
// To add a hobby post: create a new .md file in src/content/hobbies/
import { getCollection } from 'astro:content';

const hobbies = (await getCollection('hobbies'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const emojiMap: Record<string, string> = {
  Hardware: '🔧', DIY: '🔩', Baking: '🍞', Food: '🧑‍🍳',
  Photography: '📷', Analog: '🎞️', Music: '🎵', Gaming: '🎮',
  Travel: '✈️', default: '✦',
};

function getEmoji(tags: string[]) {
  for (const tag of tags) {
    if (emojiMap[tag]) return emojiMap[tag];
  }
  return emojiMap.default;
}
---

<section id="hobbies" class="py-24 px-6 bg-bg-card/30">
  <div class="max-w-5xl mx-auto">

    <p class="section-label">Outside of work</p>
    <h2 class="section-title mb-3">Hobbies</h2>
    <p class="text-ink-muted mb-12 max-w-lg">
      Things I do when the laptop is (mostly) closed.
    </p>

    <div class="grid md:grid-cols-2 gap-5 stagger">
      {hobbies.map(hobby => (
        <article data-open-drawer={`hobby-${hobby.id}`}
                 class="card-base p-6 flex gap-5 group cursor-pointer hover:-translate-y-1 transition-transform duration-200">
          <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-accent/10 border border-accent/20
                      flex items-center justify-center text-2xl group-hover:bg-accent/20 transition-colors duration-300">
            {getEmoji(hobby.data.tags)}
          </div>

          <div class="flex-1 min-w-0">
            <h3 class="font-display text-lg text-ink leading-snug mb-1.5 group-hover:text-accent transition-colors duration-300">
              {hobby.data.title}
            </h3>
            <p class="text-ink-muted text-sm leading-relaxed mb-3">
              {hobby.data.summary}
            </p>
            <div class="flex flex-wrap items-center gap-1.5">
              {hobby.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
              <span class="flex items-center gap-1 font-mono text-2xs text-ink-muted/40 group-hover:text-accent/70 transition-colors ml-auto whitespace-nowrap">
                Read
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
